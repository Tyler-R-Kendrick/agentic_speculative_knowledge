{
  "name": "agentic_speculative_knowledge",
  "dockerComposeFile": "docker-compose.yml",
  "service": "workspace",
  "runServices": [
    "workspace",
    "terminusdb"
  ],
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "shutdownAction": "stopCompose",
  "remoteUser": "vscode",
  "overrideCommand": false,
  "postCreateCommand": "python -m pip install --upgrade pip && python -m pip install -e '.[dev]' && bash /workspaces/${localWorkspaceFolderBasename}/.devcontainer/install-act.sh",
  "forwardPorts": [
    6363
  ],
  "portsAttributes": {
    "6363": {
      "label": "TerminusDB",
      "onAutoForward": "notify"
    }
  },
  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb",
    "storage": "32gb"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": [
          "tests"
        ],
        "python.analysis.extraPaths": [
          "/workspaces/${localWorkspaceFolderBasename}"
        ]
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.debugpy",
        "ms-azuretools.vscode-docker"
      ]
    }
  }
}
