# -----------------------------------------------------------------------
# Runtime-fetched files — never commit these.
#
# Workflow, agents, and shared fragments are managed by `gh aw add` /
# `gh aw update train-prompt`.  Run .devcontainer/post-start.sh to
# install them.
#
# MCP server source (agent_skills_mcp.py, server.py) and its generated
# lock file are sparse-checked-out from upstream at runtime.  Only the
# repo-specific pyproject.toml is committed.
# -----------------------------------------------------------------------

# Workflow files generated by `gh aw add` / `gh aw update`
.github/workflows/train-prompt.lock.yml
.github/workflows/train-prompt.md
.github/workflows/shared/agent-skills-runtime.md
.github/workflows/shared/trainer-loop-contract.md

# Agent files downloaded by `gh aw add` / `gh aw update`
.github/agents/

# MCP server source and generated lockfile (runtime-fetched by post-start.sh)
tools/agent-skills-mcp/agent_skills_mcp.py
tools/agent-skills-mcp/server.py
tools/agent-skills-mcp/uv.lock
